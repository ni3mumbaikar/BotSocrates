# ==========================================
# BotSocrates Environment Variables Example
# ==========================================

# Command Prefix (e.g., /, !, etc.)
PREFIX=/


# FFMpeg executable path
# Inside the Docker container, this is automatically pre-configured to /usr/bin/ffmpeg.
# On local host systems, update this to your local FFmpeg binary path.
FFMPEG_PATH=/usr/bin/ffmpeg
