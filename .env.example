# ==========================================
# BotSocrates Environment Variables Example
# ==========================================

# Command Prefix (e.g., /, !, etc.)
PREFIX=/

# MongoDB Connection URI (used for storing daily news subscribers)
# Format: mongodb://[username:password@]host[:port]/[database]
MONGO_URI=mongodb://mongodb:27017/socrates

# News API endpoint for the /technews command
NEWS_API=https://your-news-api-endpoint.com/api

# FFMpeg executable path
# Inside the Docker container, this is automatically pre-configured to /usr/bin/ffmpeg.
# On local host systems, update this to your local FFmpeg binary path.
FFMPEG_PATH=/usr/bin/ffmpeg
